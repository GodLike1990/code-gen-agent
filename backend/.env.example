# ============================================================================
# Code Gen Agent — Environment Configuration
# ============================================================================
# 复制为 .env 后修改：`cp .env.example .env`
# Makefile 会自动读取本文件的 APP_ENV 决定安装内容
# ============================================================================


# ----------------------------------------------------------------------------
# [0] 应用环境（决定安装什么依赖）
# ----------------------------------------------------------------------------
# dev  : 开发环境（默认）— 运行时 + pytest + ruff + mypy
# prod : 生产环境         — 仅核心运行时依赖，镜像最小
# full : 全家桶           — dev + redis + postgres checkpointer
APP_ENV=dev


# ----------------------------------------------------------------------------
# [1] 可选组件开关（最小化启动原则：默认都关）
# ----------------------------------------------------------------------------
# true/false，仅影响是否启用对应功能，不影响依赖安装
ENABLE_LANGSMITH=false            # 是否接入 LangSmith 链路追踪
ENABLE_LLM_REVIEW=true            # 是否启用 LLM 自审检查器（消耗额外 token）
ENABLE_SECURITY_CHECK=true        # 是否启用 Semgrep/Bandit 安全扫描
ENABLE_TEST_CHECK=true            # 是否自动运行生成代码的测试


# ----------------------------------------------------------------------------
# [2] 模型供应商选择
# ----------------------------------------------------------------------------
# 可选值: openai | anthropic | deepseek | ernie
AGENT_PROVIDER=openai


# ----------------------------------------------------------------------------
# [3] API Key（Token 方式接入 —— 最常用）
# ----------------------------------------------------------------------------
# 所有供应商都只需要这一个字段 —— 传入后即可 new 出 Agent 使用。
#
# 各供应商的 Token 获取地址：
#   - OpenAI:    https://platform.openai.com/api-keys       (格式: sk-...)
#   - Anthropic: https://console.anthropic.com/             (格式: sk-ant-...)
#   - DeepSeek:  https://platform.deepseek.com/api_keys     (格式: sk-...)
#   - ERNIE:     https://console.bce.baidu.com/qianfan/     (Qianfan AK)
AGENT_API_KEY=sk-replace-me


# ----------------------------------------------------------------------------
# [4] 模型名（可选，各供应商有默认值）
# ----------------------------------------------------------------------------
# 不配置则使用 providers.py 中的默认模型：
#   - openai    → gpt-4o-mini
#   - anthropic → claude-3-5-sonnet-latest
#   - deepseek  → deepseek-coder
#   - ernie     → ERNIE-4.0-8K
AGENT_MODEL=gpt-4o-mini


# ----------------------------------------------------------------------------
# [5] Base URL（自定义端点方式接入 —— 代理/私有部署/OpenAI 兼容服务）
# ----------------------------------------------------------------------------
# 场景 A：使用官方端点（默认，留空即可）
#
# 场景 B：使用反向代理 / 本地模型 / 第三方 OpenAI 兼容服务
#   取消注释并填写，AGENT_PROVIDER 保持 openai（因为大多遵循 OpenAI 协议）
#
# 常见示例：
#
#   # Ollama 本地模型
#   AGENT_BASE_URL=http://localhost:11434/v1
#   AGENT_MODEL=qwen2.5-coder
#   AGENT_API_KEY=ollama
#
#   # Groq / Together / vLLM 等
#   AGENT_BASE_URL=https://api.groq.com/openai/v1
#   AGENT_MODEL=llama-3.1-70b-versatile
#
#   # Azure OpenAI
#   AGENT_BASE_URL=https://<resource>.openai.azure.com/openai/deployments/<deployment>
#
# ⚠️ 末尾不要带 `#` / `/` / 空格，否则 httpx/SDK 会做 URL 校验报错。
AGENT_BASE_URL=


# ----------------------------------------------------------------------------
# [6] 状态持久化后端
# ----------------------------------------------------------------------------
# 可选值: sqlite | redis | db | memory
#   - sqlite : 本地文件（默认，最小启动）
#   - redis  : 需要 APP_ENV=full 或手动装 langgraph-checkpoint-redis
#   - db     : 需要 APP_ENV=full 或手动装 langgraph-checkpoint-postgres
#   - memory : 进程内（不持久化，测试用）
AGENT_STATE_BACKEND=sqlite

# DSN 根据后端类型不同：
#   - sqlite: 文件路径            .agent_state.sqlite
#   - redis : redis://host:port/0
#   - db    : postgresql://user:pass@host:5432/dbname
AGENT_STATE_DSN=.agent_state.sqlite


# ----------------------------------------------------------------------------
# [7] LangSmith 链路追踪
# ----------------------------------------------------------------------------
# 仅当 ENABLE_LANGSMITH=true 时生效
AGENT_LANGSMITH_PROJECT=code-gen-agent
LANGSMITH_API_KEY=


# ----------------------------------------------------------------------------
# [8] 服务器监听
# ----------------------------------------------------------------------------
AGENT_HOST=0.0.0.0
AGENT_PORT=8000


# ----------------------------------------------------------------------------
# [9] 日志与需求记录（本地文件存储）
# ----------------------------------------------------------------------------
# DEBUG | INFO | WARNING | ERROR
AGENT_LOG_LEVEL=INFO

# 日志文件路径（相对 backend 工作目录）
# 目录会自动创建；文件采用 JSON Lines 格式，10MB 滚动、保留 5 份
AGENT_LOG_FILE=logs/agent.log

# 每次提交的需求记录目录（与 graph state 职责拆分：
#   - graph state  → AGENT_STATE_DSN (.agent_state.sqlite)
#   - 需求记录     → AGENT_REQUESTS_DIR/<thread_id>.json
#   - 生成代码     → AGENT_WORKSPACE_ROOT/<thread_id>/
# 前端 History 页从此目录拉列表
AGENT_REQUESTS_DIR=data/requests

# 生成代码产出目录：每个 thread 一个子目录 <tid>/，里面是 codegen 节点写出的文件
AGENT_WORKSPACE_ROOT=data/workspaces
